rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isTeacher() {
      return isSignedIn() && getUserData().role == 'teacher';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // User Profiles
    match /users/{userId} {
      allow get: if isSignedIn();
      allow create: if isOwner(userId) 
        && request.resource.data.keys().hasAll(['uid', 'email', 'role', 'createdAt'])
        && request.resource.data.uid == request.auth.uid;
      allow update: if isOwner(userId);
    }

    // Classrooms
    match /classrooms/{classroomId} {
      allow read: if isSignedIn() && (
        resource.data.teacherId == request.auth.uid ||
        request.auth.uid in resource.data.students
      );
      allow create: if isTeacher();
      allow update: if isSignedIn() && (
        resource.data.teacherId == request.auth.uid ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['students']))
      );
    }

    // Lectures
    match /lectures/{lectureId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Subjects
    match /subjects/{subjectId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
